  "apiEndpoints": [
    {
      "method": "GET",
      "path": "/api/todos",
      "description": "Retrieve a list of todos",
      "requestBody": "{}",
      "responseBody": "Array<Todo>"
    },
    {
      "method": "POST",
      "path": "/api/todos",
      "description": "Create a new todo",
      "requestBody": "Todo",
      "responseBody": "Todo"
    },
    {
      "method": "GET",
      "path": "/api/todos/:id",
      "description": "Retrieve a single todo",
      "requestBody": "{}",
      "responseBody": "Todo"
    },
    {
      "method": "PUT",
      "path": "/api/todos/:id",
      "description": "Update a single todo",
      "requestBody": "Todo",
      "responseBody": "Todo"
    },
    {
      "method": "DELETE",
      "path": "/api/todos/:id",
      "description": "Delete a single todo",
      "requestBody": "{}",
      "responseBody": "{}"
    }
  ],
  "databaseSchema": "model Todo {\n  id       String   @id @default(cuid())\n  title    String\n  completed Boolean\n  dueDate  DateTime\n  priority Integer\n}\n",
  "envVariables": [
    "DATABASE_URL",
    "NEXTAUTH_SECRET"
  ],
  "dependencies": {
    "next": "^12.2.5",
    "next-auth": "^4.2.1",
    "prisma": "^4.2.1",
    "prisma-client": "^4.2.1"
  },
  "buildConfig": "npm run build && npm run start"
}