  "databaseSchema": "model User {\n  id       String   @id @default(cuid())\n  email    String   @unique\n  password String\n}\n\nmodel Task {\n  id       String   @id @default(cuid())\n  title    String\n  user     User     @relation(fields: [userId], references: [id])\n  userId   String\n}",
  "envVariables": [
