  "apiEndpoints": [
    {
      "method": "POST",
      "path": "/api/calculator",
      "description": "Perform arithmetic operations (add, subtract, multiply, divide)",
      "requestBody": "{\"type\":\"object\",\"properties\":{\"operation\":{\"type\":\"string\",\"enum\":[\"add\",\"subtract\",\"multiply\",\"divide\"]},\"a\":{\"type\":\"number\"},\"b\":{\"type\":\"number\"}},\"required\":[\"operation\",\"a\",\"b\"]}",
      "responseBody": "{\"type\":\"object\",\"properties\":{\"result\":{\"type\":\"number\"},\"error\":{\"type\":\"string\"}}}"
    },
    {
      "method": "GET",
      "path": "/api/calculation-history",
      "description": "Get calculation history for authenticated user",
      "requestBody": null,
      "responseBody": "{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"integer\"},\"operation\":{\"type\":\"string\"},\"a\":{\"type\":\"number\"},\"b\":{\"type\":\"number\"},\"result\":{\"type\":\"number\"},\"createdAt\":{\"type\":\"string\",\"format\":\"date-time\"}}}}"
    },
    {
      "method": "POST",
      "path": "/api/calculation-history",
      "description": "Save calculation to history",
      "requestBody": "{\"type\":\"object\",\"properties\":{\"operation\":{\"type\":\"string\"},\"a\":{\"type\":\"number\"},\"b\":{\"type\":\"number\"},\"result\":{\"type\":\"number\"}},\"required\":[\"operation\",\"a\",\"b\",\"result\"]}",
      "responseBody": "{\"type\":\"object\",\"properties\":{\"id\":{\"type\":\"integer\"},\"success\":{\"type\":\"boolean\"}}}"
    },
