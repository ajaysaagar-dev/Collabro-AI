model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]
}

model Task {
  id       String   @id @default(cuid())
  title    String
  description String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  status   TaskStatus @default(OPEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  dueDate  DateTime
  reminders Reminder[]
  comments Comment[]
  assignedTo User[]
  priority  Int
  order    Int
}

model TaskStatus {
  id   String   @id @default(cuid())
  name String   @unique
}

model Reminder {
  id       String   @id @default(cuid())
  task     Task     @relation(fields: [taskId], references: [id])
  taskId   String
  time     DateTime
  message  String
}

model Comment {
  id       String   @id @default(cuid())
  task     Task     @relation(fields: [taskId], references: [id])
  taskId   String
  text     String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  createdAt DateTime @default(now())
}

model TaskPriority {
  id   String   @id @default(cuid())
  name String   @unique
}

model UserTask {
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  task     Task     @relation(fields: [taskId], references: [id])
  taskId   String
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}