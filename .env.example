# ─── Collabro-AI Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Model Providers ─────────────────────────────────────────────────────────
# OpenAI (required for embeddings; also primary completion provider)
OPENAI_API_KEY=sk-...

# Anthropic Claude (secondary/fallback completion provider)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (optional — local offline models, no cost)
# OLLAMA_HOST=http://localhost:11434

# ─── Database (Episodic + Semantic Memory) ───────────────────────────────────
# PostgreSQL with pgvector extension for semantic memory.
# Leave unset to use in-memory fallback (no persistence across restarts).
# DB_URL=postgresql://user:password@localhost:5432/collabro_ai

# ─── Redis (Working Memory) ──────────────────────────────────────────────────
# Optional: leave unset to use in-process Map (single-server, ephemeral).
# REDIS_URL=redis://localhost:6379

# ─── Sandbox ─────────────────────────────────────────────────────────────────
# Set to 'docker' for full isolation, 'mock' for testing, 'host' for dev.
SANDBOX_PROVIDER=host

# ─── Orchestrator Budgets (all optional, defaults shown) ─────────────────────
MAX_REPAIR_LOOPS=5
MAX_WALL_CLOCK_MINUTES=15
MAX_TOKENS_PER_RUN=0
MAX_SANDBOX_RESTARTS=2

# ─── Dashboard ───────────────────────────────────────────────────────────────
# Rate-limit the /api/generate endpoint (requests per minute per IP)
GENERATE_RATE_LIMIT_RPM=10

# ─── Storage (Screenshots, HTML Snapshots) ────────────────────────────────────
# 'local' saves to ./storage/ directory; 's3' uploads to S3.
STORAGE_PROVIDER=local
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=collabro-ai-artifacts
